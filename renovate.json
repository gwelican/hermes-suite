{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeBranch",
    ":rebaseStalePrs"
  ],
  "labels": ["dependencies", "renovate"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track hermes-agent Docker image version in versions.env",
      "fileMatch": ["^versions.env$"],
      "matchStrings": [
        "AGENT_VERSION=(?<currentValue>v?[\\d.]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "nousresearch/hermes-agent",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Track hermes-webui GitHub release version in versions.env",
      "fileMatch": ["^versions.env$"],
      "matchStrings": [
        "WEBUI_VERSION=(?<currentValue>v?[\\d.]+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "nesquena/hermes-webui",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Track agentmemory npm package version in agentmemory/versions.env",
      "fileMatch": ["^agentmemory/versions\\.env$"],
      "matchStrings": [
        "AGENTMEMORY_VERSION=(?<currentValue>[\\d.]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "@agentmemory/agentmemory",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Track Obsidian Sync CLI version in Dockerfile",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG OBSIDIAN_HEADLESS_VERSION=(?<currentValue>[\\d.]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "obsidian-headless",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge version bumps for bundled components",
      "matchDatasources": ["docker", "github-tags", "npm"],
      "matchDepNames": ["nousresearch/hermes-agent", "nesquena/hermes-webui", "@agentmemory/agentmemory", "obsidian-headless"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ]
}
